---
import GitHub from "./icons/GitHub.astro"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"
import Django from "./icons/Django.astro"
import Flask from "./icons/Flask.astro"
import Bootstrap from "./icons/Bootstrap.astro"
import Python from "./icons/Python.astro"
import Javascript from "./icons/Javascript.astro"
import ReactNative from "./icons/ReactNative.astro"
import TypeScript from "./icons/TypeScript.astro"

const TAGS = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
    DJANGO: {
    name: "Django",
    class: "bg-[#092E20] text-white",
    icon: Django,
  },
  FLASK: {
  name: "Flask",
  class: "bg-[#092E20] text-white",
  icon: Flask,
  },
  BOOTSTRAP: {
    name: "Bootstrap",
    class: "bg-[#092E20] text-white",
    icon: Bootstrap,
  },
  PYTHON: {
    name: "Python",
    class: "bg-[#092E20] text-white",
    icon: Python,
  },
  JAVASCRIPT: {
    name: "Javascript",
    class: "bg-[#092E20] text-white",
    icon: Javascript,
  },
  REACT_NATIVE: {
    name: "React Native",
    class: "bg-[#003159] text-white",
    icon: ReactNative,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "bg-[#003159] text-white",
    icon: TypeScript,
  },
}
const PROJECTS = [
    {
    title: "Checkealo - Escáner Nutricional",
    description:
      "Aplicación móvil que permite al usuario en el supermercado escanear códigos de barras con la cámara. Implementa un servicio que consume la API de Open Food Facts para traer los datos del producto, compararlos con la condición del usuario y entregar una devolución nutricional personalizada al instante.",
    link: "", 
    github: "https://github.com/hoodlucas/Checkealo",
    image: "/projects/chequealo2.jpg",
    tags: [TAGS.REACT_NATIVE, TAGS.TYPESCRIPT],
  },
  {
    title: "Pozos Ya",
    description:
      "Aplicación web de gestión de reclamos de baches que facilita el reporte ciudadano geolocalizado y provee al Municipio herramientas de administración, priorización y análisis mediante mapas y gráficos.",
    link: "", 
    github: "https://github.com/hoodlucas/pozos-ya", 
    image: "/projects/pozos-ya.jpg",
    tags: [TAGS.PYTHON, TAGS.DJANGO],
  },
  {
  title: "Sistema de Gestión de Cursos",
  description:
    "Proyecto académico completo para gestionar clases, materiales, docentes y alumnos.",
  link: "", 
  github: "https://github.com/hoodlucas/language_institute",
  image: "/projects/language-institute.jpg",
  tags: [TAGS.PYTHON, TAGS.DJANGO, TAGS.JAVASCRIPT],
  },
  {
    title: "Kiosco Online – Made in Argentina",
    description:
      "Simulación de un e-commerce con productos típicos argentinos. Proyecto final inspirado en el comercio local.",
    link: "", // si lo subís a producción, lo agregamos
    github: "https://github.com/hoodlucas/MadeInArgentina",
    image: "/projects/made-in-arg.jpg",
    tags: [TAGS.PYTHON, TAGS.FLASK, TAGS.BOOTSTRAP],
  }
]
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
      <img alt="Foto del proyecto" class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105" loading="eager" src={image} />
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row mb-2 gap-x-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                <tag.icon class="size-4" />
                {tag.name}
              </span>
            </li>
          ))}
        </ul>

      <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
      <footer class="flex items-end justify-start mt-4 gap-x-4">
          {github && (
            <LinkButton href={github}>
              <GitHub class="size-6" />
              Code
              
            </LinkButton>
          )}
          {link && (
            <LinkButton href={link}>
              <Link class="size-4" />
              Preview
            </LinkButton>
          )}
        </footer>
    </div>
  </div>
</article>
    ))
  }
</div>



